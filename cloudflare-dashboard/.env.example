# Paperfly Dashboard - Environment Variables Example
# 
# This is a template for environment variables
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual values
# 3. Never commit .env to version control!

# Your Paperfly local server URL
# Default for local runs: http://127.0.0.1:3000
# Example: http://127.0.0.1:3000
API_BASE=http://127.0.0.1:3000

# Optional: Custom domain (if not using workers.dev)
# CUSTOM_DOMAIN=dashboard.yourdomain.com

# Optional: Log refresh interval in milliseconds (default: 30000 = 30 seconds)
# REFRESH_INTERVAL=30000

# Optional: Maximum logs to fetch (default: 100)
# MAX_LOGS=100
